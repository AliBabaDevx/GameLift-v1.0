<Window x:Class="GameLift.SettingsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="GameLift Settings" Width="560" Height="655" WindowStartupLocation="CenterOwner" Background="#11121A" ResizeMode="NoResize">
  <Grid Margin="24"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel><TextBlock Text="Einstellungen" FontSize="26" FontWeight="SemiBold"/><TextBlock Text="GameLift verwaltet alle Profildaten lokal auf diesem PC." Foreground="#A5A1B2" Margin="0,5,0,0"/></StackPanel>
    <ScrollViewer Grid.Row="1" Margin="0,26,0,0" VerticalScrollBarVisibility="Auto"><StackPanel><Border Background="#1B1C26" CornerRadius="10" Padding="15"><DockPanel><StackPanel><TextBlock Text="Sprache" FontWeight="SemiBold"/><TextBlock x:Name="LanguageText" Text="Deutsch" Foreground="#A5A1B2" Margin="0,4,0,0"/></StackPanel><Button DockPanel.Dock="Right" x:Name="LanguageButton" Content="Zu Englisch" Click="LanguageButton_Click" Background="#6E52CE" Margin="12,3,0,0"/></DockPanel></Border><Border Background="#1B1C26" CornerRadius="10" Padding="15" Margin="0,10,0,0"><StackPanel><TextBlock Text="Community-Links" FontWeight="SemiBold"/><TextBlock Text="Trage hier deine eigenen Projekt-Links ein. Die Buttons im Launcher öffnen genau diese Ziele." Foreground="#A5A1B2" TextWrapping="Wrap" Margin="0,4,0,8"/><TextBlock Text="GitHub" Foreground="#C6C1D5"/><TextBox x:Name="GitHubBox"/><TextBlock Text="Discord" Foreground="#C6C1D5"/><TextBox x:Name="DiscordBox"/><TextBlock Text="YouTube" Foreground="#C6C1D5"/><TextBox x:Name="YouTubeBox"/><Button Content="Links speichern" Click="SaveLinks_Click" Background="#6E52CE" HorizontalAlignment="Left" Margin="0,0,0,0"/></StackPanel></Border><Border Background="#1B1C26" CornerRadius="10" Padding="15" Margin="0,10,0,0"><DockPanel><StackPanel><TextBlock Text="Lokale Daten &amp; Backup" FontWeight="SemiBold"/><TextBlock Text="Profile und Sessions als JSON sichern oder den Ordner öffnen." Foreground="#A5A1B2" Margin="0,4,0,0"/></StackPanel><StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,3,0,0"><Button Content="Backup" Click="Backup_Click"/><Button Content="Ordner" Click="OpenFolder_Click" Margin="6,0,0,0"/></StackPanel></DockPanel></Border><Border Background="#1B1C26" CornerRadius="10" Padding="15" Margin="0,10,0,0"><StackPanel><TextBlock Text="Sicherheit" FontWeight="SemiBold"/><TextBlock Text="GameLift verändert keine Spieldateien und beendet nur Apps, die du in einem Profil hinterlegt hast." Foreground="#A5A1B2" TextWrapping="Wrap" Margin="0,4,0,0"/></StackPanel></Border><TextBlock Text="GameLift 1.0.0 · Windows · lokal-first" Foreground="#777384" FontSize="11" HorizontalAlignment="Center" Margin="0,14,0,0"/></StackPanel></ScrollViewer>
    <Button Grid.Row="2" Content="Fertig" Click="Close_Click" HorizontalAlignment="Right" Background="#6E52CE" Margin="0"/>
  </Grid>
</Window>
