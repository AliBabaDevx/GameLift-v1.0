<Window x:Class="GameLift.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="GameLift" Width="1360" Height="800" MinWidth="1050" MinHeight="650" Background="#0C0D12">
  <Grid>
    <Grid.RowDefinitions><RowDefinition Height="52"/><RowDefinition Height="*"/><RowDefinition Height="38"/></Grid.RowDefinitions>
    <Border Grid.Row="0" BorderBrush="#303143" BorderThickness="0,0,0,1"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#171A2A" Offset="0"/><GradientStop Color="#5140A1" Offset="1"/></LinearGradientBrush></Border.Background><Grid Margin="18,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Border Background="#A882FF" CornerRadius="7" Width="30" Height="30"><TextBlock Text="GL" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="White" FontSize="11"/></Border><TextBlock Text="GameLift" FontSize="17" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/><TextBlock Text="GAMING TOOLKIT" Foreground="#BDB5E5" FontSize="10" Margin="10,2,0,0" VerticalAlignment="Center"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="Local · Private" Foreground="#DDD8F4" Margin="0,0,14,0" VerticalAlignment="Center"/><Button x:Name="LanguageButton" Content="DE" Click="ToggleLanguage_Click" Background="#6B55C2" Padding="12,6" Margin="0"/></StackPanel></Grid></Border>
    <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="72"/><ColumnDefinition Width="286"/><ColumnDefinition Width="*"/><ColumnDefinition Width="280"/></Grid.ColumnDefinitions>
      <Border Background="#11121A" BorderBrush="#292A36" BorderThickness="0,0,1,0"><DockPanel><StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,14,0,0"><Button Style="{StaticResource RailButton}" Content="◈" Background="#513B92" Foreground="White" Tag="dashboard" Click="RailButton_Click" ToolTip="Dashboard"/><Button Style="{StaticResource RailButton}" Content="⌁" Tag="library" Click="RailButton_Click" ToolTip="Bibliothek"/><Button Style="{StaticResource RailButton}" Content="◉" Tag="network" Click="RailButton_Click" ToolTip="Netzwerktest"/><Button Style="{StaticResource RailButton}" Content="◷" Tag="history" Click="RailButton_Click" ToolTip="Sitzungsverlauf"/><Button Style="{StaticResource RailButton}" Content="▣" Tag="new" Click="RailButton_Click" ToolTip="Neues Spiel"/></StackPanel><Button DockPanel.Dock="Bottom" Style="{StaticResource RailButton}" Content="⚙" Tag="settings" Click="RailButton_Click" ToolTip="Einstellungen" Margin="0,0,0,14"/></DockPanel></Border>
      <Border Grid.Column="1" Background="#12131B" BorderBrush="#292A36" BorderThickness="0,0,1,0" Padding="16"><DockPanel><Button x:Name="NewProfileButton" DockPanel.Dock="Bottom" Content="＋ Neues Spiel" Click="NewProfile_Click" Background="#6E52CE" Margin="0,14,0,0"/><StackPanel DockPanel.Dock="Top"><TextBlock Text="DEINE BIBLIOTHEK" Foreground="#9C99AA" FontSize="10" FontWeight="SemiBold"/><TextBlock Text="Spiele" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,13"/><TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" ToolTip="Spiel suchen" Margin="0,0,0,7"/><CheckBox x:Name="FavoritesOnlyBox" Content="Nur Favoriten" Checked="FilterChanged" Unchecked="FilterChanged"/></StackPanel><ListBox x:Name="ProfilesList" DisplayMemberPath="DisplayName" SelectionChanged="ProfilesList_SelectionChanged" Background="Transparent" BorderThickness="0"/></DockPanel></Border>
      <Grid Grid.Column="2" Margin="24,22"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="ProfileTitleText" Text="Gaming Dashboard" FontSize="27" FontWeight="SemiBold"/><TextBlock x:Name="SubtitleText" Text="Bereite dein Setup vor und starte fokussiert." Foreground="#A5A1B2" Margin="0,4,0,0"/></StackPanel><Button Grid.Column="1" x:Name="NetworkButton" Content="◉ Verbindung testen" Click="NetworkTest_Click" Background="#252635" Margin="0,8,0,0"/></Grid>
        <Grid Grid.Row="1" Margin="0,22,0,22"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Border Background="#191A24" BorderBrush="#2A2B38" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0"><StackPanel><TextBlock Text="BIBLIOTHEK" Foreground="#9B98AA" FontSize="10"/><TextBlock x:Name="ProfileCountText" Text="0 Spiele" FontSize="21" FontWeight="SemiBold" Foreground="#A882FF" Margin="0,5,0,0"/></StackPanel></Border><Border Grid.Column="1" Background="#191A24" BorderBrush="#2A2B38" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0"><StackPanel><TextBlock Text="GESTARTET" Foreground="#9B98AA" FontSize="10"/><TextBlock x:Name="LaunchCountText" Text="0 insgesamt" FontSize="21" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel></Border><Border Grid.Column="2" Background="#191A24" BorderBrush="#2A2B38" BorderThickness="1" CornerRadius="10" Padding="14"><StackPanel><TextBlock Text="LETZTE SESSION" Foreground="#9B98AA" FontSize="10"/><TextBlock x:Name="LastPlayedText" Text="Noch keines" TextTrimming="CharacterEllipsis" FontSize="21" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel></Border></Grid>
        <Border Grid.Row="2" Background="#161720" BorderBrush="#2A2B38" BorderThickness="1" CornerRadius="12" Padding="22"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel><DockPanel Margin="0,0,0,18"><StackPanel><TextBlock Text="LAUNCH PROFILE" Foreground="#A882FF" FontSize="10" FontWeight="SemiBold"/><TextBlock Text="Konfiguration" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel><CheckBox x:Name="FavoriteBox" DockPanel.Dock="Right" Content="Favorit" Click="FavoriteBox_Click" VerticalAlignment="Center"/></DockPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="15"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="NameLabel" Text="Name"/><TextBox x:Name="NameBox"/><TextBlock Text="Kategorie"/><TextBox x:Name="CategoryBox" Text="General"/></StackPanel><StackPanel Grid.Column="2"><TextBlock x:Name="PathLabel" Text="Spiel-EXE"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="PathBox" Margin="0,5,8,13"/><Button Grid.Column="1" x:Name="BrowseButton" Content="Datei" Click="Browse_Click" Padding="12,8" Margin="0,5,0,13"/></Grid><TextBlock Text="Startargumente"/><TextBox x:Name="ArgumentsBox" ToolTip="z. B. -dx11 -windowed"/></StackPanel></Grid><TextBlock x:Name="ProcessesLabel" Text="Hintergrundprogramme schließen (durch Komma trennen)" Foreground="#C5C1D0"/><TextBox x:Name="ProcessesBox" ToolTip="chrome, discord, ..."/><WrapPanel><CheckBox x:Name="PowerPlanBox" Content="Höchstleistung" Margin="0,3,20,10"/><CheckBox x:Name="OverlayBox" Content="Performance HUD" Margin="0,3,20,10"/></WrapPanel><Border Background="#101117" CornerRadius="8" Padding="12" Margin="0,3,0,18"><TextBlock x:Name="HintText" Text="GameLift beendet ausschließlich Programme, die du selbst einträgst. Dein Energieschema wird danach wiederhergestellt." Foreground="#A5A1B2" TextWrapping="Wrap"/></Border><StackPanel Orientation="Horizontal"><Button x:Name="LaunchButton" Content="▶ Spiel starten" Background="#7A55E5" Click="Launch_Click"/><Button x:Name="SaveButton" Content="Speichern" Click="Save_Click"/><Button x:Name="DeleteButton" Content="Löschen" Background="#3A2634" Click="Delete_Click"/></StackPanel></StackPanel></ScrollViewer></Border>
      </Grid>
      <Border Grid.Column="3" Background="#12131B" BorderBrush="#292A36" BorderThickness="1,0,0,0" Padding="18"><DockPanel><StackPanel DockPanel.Dock="Top"><TextBlock Text="LIVE STATUS" Foreground="#A882FF" FontSize="10" FontWeight="SemiBold"/><TextBlock Text="Dein System" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,18"/><Border Background="#1B1C26" CornerRadius="10" Padding="14"><StackPanel><TextBlock Text="NETZWERKTEST" Foreground="#9B98AA" FontSize="10"/><TextBlock x:Name="NetworkText" Text="Bereit zum Test" FontSize="16" FontWeight="SemiBold" Margin="0,7,0,0"/><TextBlock Text="Testet Latenz zu 1.1.1.1" Foreground="#878394" FontSize="11" Margin="0,5,0,0"/></StackPanel></Border><TextBlock Text="LETZTE SESSION" Foreground="#A882FF" FontSize="10" FontWeight="SemiBold" Margin="0,24,0,9"/><Border Background="#1B1C26" CornerRadius="10" Padding="14"><StackPanel><TextBlock x:Name="RecentSessionText" Text="Noch keine Session" FontWeight="SemiBold" TextWrapping="Wrap"/><TextBlock Text="Verlauf über die Uhr in der Seitenleiste." Foreground="#878394" FontSize="11" Margin="0,6,0,0"/></StackPanel></Border><TextBlock Text="QUICK TIP" Foreground="#A882FF" FontSize="10" FontWeight="SemiBold" Margin="0,24,0,9"/><Border Background="#1B1C26" CornerRadius="10" Padding="14"><StackPanel><TextBlock Text="Sicher optimieren" FontWeight="SemiBold"/><TextBlock Text="Aktiviere den HUD-Modus und schließe nur Programme, die du nicht brauchst." Foreground="#A5A1B2" TextWrapping="Wrap" Margin="0,7,0,0"/></StackPanel></Border></StackPanel><StackPanel DockPanel.Dock="Bottom"><Separator Background="#2A2B38" Margin="0,12"/><TextBlock Text="COMMUNITY" Foreground="#A882FF" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/><WrapPanel><Button Content="GH" Tag="github" Click="SocialButton_Click" ToolTip="GitHub" Padding="10,7"/><Button Content="DC" Tag="discord" Click="SocialButton_Click" ToolTip="Discord" Padding="10,7" Margin="6,0,0,0"/><Button Content="YT" Tag="youtube" Click="SocialButton_Click" ToolTip="YouTube" Padding="10,7" Margin="6,0,0,0"/></WrapPanel></StackPanel></DockPanel></Border>
    </Grid>
    <Border Grid.Row="2" Background="#11121A" BorderBrush="#292A36" BorderThickness="0,1,0,0" Padding="18,0"><TextBlock x:Name="StatusText" Text="Bereit. Erstelle ein Profil oder wähle eines aus." VerticalAlignment="Center" Foreground="#AAA6B7" FontSize="11"/></Border>
  </Grid>
</Window>
